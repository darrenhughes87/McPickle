PORT=3003
ADMIN_PASSWORD=changeme

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@mcpickles.pivotalsl.co.uk

# Optional: Monzo (or any) payment link shown to confirmed-roster players
# after the roster is published. Static link — the app never tracks who
# paid, so it'll keep showing for everyone on the roster every session.
# Set to a blank line / leave commented to hide the button entirely.
PAYMENT_LINK=https://monzo.me/example/1.50

# TZ is hardcoded as Europe/London in docker-compose.yml — no need to set it here
